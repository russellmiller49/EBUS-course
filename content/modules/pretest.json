  "questions": [
    {
      "id": "pretest-01",
      "prompt": "A 64-year-old woman with heavy smoking history has a 4.2 cm spiculated peripheral right upper lobe lung mass. PET/CT shows multiple mediastinal nodes that are all subcentimeter in size and without significant FDG avidity. She is an operative candidate. Which is the best next step in management?",
      "type": "scenario",
      "imageAssetKey": null,
      "options": [
        {
          "id": "a",
          "label": "CT-guided transthoracic needle biopsy of the lung mass"
        },
        {
          "id": "b",
          "label": "Proceed to right upper lobectomy"
        },
        {
          "id": "c",
          "label": "Systematic cpEBUS-TBNA mediastinal staging"
        },
        {
          "id": "d",
          "label": "Mediastinoscopy for directed mediastinal staging"
        }
      ],
      "correctOptionId": "c"
    },
    {
      "id": "pretest-02",
      "prompt": "While imaging a right paratracheal node, multiple bright parallel lines at regular intervals suddenly appear on the EBUS monitor. Which next step is best?",
      "type": "single-best-answer",
      "imageAssetKey": null,
      "options": [
        {
          "id": "a",
          "label": "Adjust the saline-filled balloon against the airway wall"
        },
        {
          "id": "b",
          "label": "Increase suction through the working channel"
        },
        {
          "id": "c",
          "label": "Activate elastography before re-imaging"
        },
        {
          "id": "d",
          "label": "Advance the needle to anchor the scope"
        }
      ],
      "correctOptionId": "a"
    },
    {
