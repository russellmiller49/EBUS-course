{
  "id": "pretest",
  "title": "EBUS 2026 Pre-Test",
  "summary": "Baseline 20-question assessment from the 2026 pre-course test set. Scores are recorded before the practice modules and lecture sequence unlock.",
  "instructions": [
    "Complete the full pre-test after the welcome and course introduction video.",
